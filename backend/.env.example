# Base de datos (Supabase)
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxx.supabase.co:5432/postgres

# JWT
JWT_SECRET=tu_jwt_secret_de_64_caracteres_aqui

# CORS — URL de tu frontend en Vercel
ALLOWED_ORIGINS=https://acompania-web.vercel.app

# AWS Lambda (verificación de identidad)
AWS_LAMBDA_URL=https://xxx.execute-api.us-east-1.amazonaws.com

# Cloudinary (fotos de perfil)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Resend (emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Firebase (push notifications)
FIREBASE_SERVER_KEY=AAAA_xxxxxxxxxxxx

# Puerto (Railway lo asigna automáticamente)
PORT=3000
